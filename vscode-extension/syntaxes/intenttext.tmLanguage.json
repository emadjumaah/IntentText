{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "IntentText",
  "scopeName": "source.intenttext",
  "patterns": [
    { "include": "#code-block" },
    { "include": "#checkbox-done" },
    { "include": "#checkbox-todo" },
    { "include": "#title-keyword" },
    { "include": "#section-keywords" },
    { "include": "#task-keyword" },
    { "include": "#done-keyword" },
    { "include": "#callout-keywords" },
    { "include": "#table-keywords" },
    { "include": "#media-keywords" },
    { "include": "#meta-keywords" },
    { "include": "#divider-keyword" },
    { "include": "#list-item" },
    { "include": "#pipe-metadata" },
    { "include": "#inline-bold" },
    { "include": "#inline-italic" },
    { "include": "#inline-strike" },
    { "include": "#inline-code" },
    { "include": "#inline-link" },
    { "include": "#shortcut-priority" },
    { "include": "#shortcut-mention" },
    { "include": "#shortcut-emoji-date" }
  ],
  "repository": {
    "code-block": {
      "begin": "^(code:)\\s*$",
      "end": "^(end:)\\s*$",
      "beginCaptures": {
        "1": { "name": "keyword.control.code.intenttext" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.code.intenttext" }
      },
      "contentName": "markup.raw.block.intenttext"
    },
    "checkbox-done": {
      "match": "^(\\[x\\])(.*)$",
      "captures": {
        "1": { "name": "keyword.control.done.intenttext" },
        "2": { "name": "markup.strikethrough.intenttext" }
      }
    },
    "checkbox-todo": {
      "match": "^(\\[ \\])(.*)$",
      "captures": {
        "1": { "name": "keyword.control.task.intenttext" },
        "2": { "name": "string.other.intenttext" }
      }
    },
    "title-keyword": {
      "match": "^(title|summary)(:)(.*)$",
      "captures": {
        "1": { "name": "entity.name.tag.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "markup.bold.intenttext" }
      }
    },
    "section-keywords": {
      "match": "^(section|sub2|sub)(:)(.*)$",
      "captures": {
        "1": { "name": "keyword.control.section.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "entity.name.section.intenttext" }
      }
    },
    "task-keyword": {
      "match": "^(task)(:)(.*)$",
      "captures": {
        "1": { "name": "keyword.control.task.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.other.intenttext" }
      }
    },
    "done-keyword": {
      "match": "^(done)(:)(.*)$",
      "captures": {
        "1": { "name": "keyword.control.done.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "markup.strikethrough.intenttext" }
      }
    },
    "callout-keywords": {
      "match": "^(note|info|warning|tip|success|question)(:)(.*)$",
      "captures": {
        "1": { "name": "keyword.control.callout.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.other.intenttext" }
      }
    },
    "table-keywords": {
      "match": "^(headers|row)(:)(.*)$",
      "captures": {
        "1": { "name": "keyword.control.table.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.other.intenttext" }
      }
    },
    "media-keywords": {
      "match": "^(image|link|embed|ref)(:)(.*)$",
      "captures": {
        "1": { "name": "keyword.control.media.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "markup.underline.link.intenttext" }
      }
    },
    "meta-keywords": {
      "match": "^(template|use|include|ai|synthesize|comment)(:)(.*)$",
      "captures": {
        "1": { "name": "keyword.other.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.other.intenttext" }
      }
    },
    "divider-keyword": {
      "match": "^(divider)(:)(.*)$",
      "captures": {
        "1": { "name": "comment.line.intenttext" },
        "2": { "name": "comment.line.intenttext" },
        "3": { "name": "comment.line.intenttext" }
      }
    },
    "list-item": {
      "match": "^([-*]|\\d+\\.)\\s",
      "name": "punctuation.definition.list.intenttext"
    },
    "pipe-metadata": {
      "match": "(\\|)\\s*([\\w-]+)(:)([^|]*)",
      "captures": {
        "1": { "name": "punctuation.separator.pipe.intenttext" },
        "2": { "name": "variable.other.property.intenttext" },
        "3": { "name": "punctuation.separator.intenttext" },
        "4": { "name": "string.other.value.intenttext" }
      }
    },
    "inline-bold": {
      "match": "\\*([^*\\n]+)\\*",
      "captures": {
        "1": { "name": "markup.bold.intenttext" }
      }
    },
    "inline-italic": {
      "match": "(?<![\\w])_([^_\\n]+)_(?![\\w])",
      "captures": {
        "1": { "name": "markup.italic.intenttext" }
      }
    },
    "inline-strike": {
      "match": "~([^~\\n]+)~",
      "captures": {
        "1": { "name": "markup.strikethrough.intenttext" }
      }
    },
    "inline-code": {
      "match": "```([^`\\n]*)```",
      "captures": {
        "1": { "name": "markup.raw.inline.intenttext" }
      }
    },
    "inline-link": {
      "match": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "captures": {
        "1": { "name": "string.other.link.title.intenttext" },
        "2": { "name": "markup.underline.link.intenttext" }
      }
    },
    "shortcut-priority": {
      "match": "!(low|medium|high|critical)\\b",
      "name": "constant.language.priority.intenttext"
    },
    "shortcut-mention": {
      "match": "@[\\w]+",
      "name": "variable.other.mention.intenttext"
    },
    "shortcut-emoji-date": {
      "match": "📅\\s*\\S+",
      "name": "constant.language.date.intenttext"
    }
  }
}
