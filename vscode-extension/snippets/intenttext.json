{
  "Title": {
    "prefix": "title",
    "body": ["title: ${1:Document Title}"],
    "description": "Document title"
  },
  "Summary": {
    "prefix": "summary",
    "body": ["summary: ${1:Brief description}"],
    "description": "Document summary"
  },
  "Section": {
    "prefix": "section",
    "body": ["section: ${1:Section Name}"],
    "description": "Major section"
  },
  "Sub-section": {
    "prefix": "sub",
    "body": ["sub: ${1:Sub-section Name}"],
    "description": "Sub-section"
  },
  "Task": {
    "prefix": "task",
    "body": ["task: ${1:Description} | owner: ${2:name} | due: ${3:date}"],
    "description": "Task with metadata"
  },
  "Task shortcut": {
    "prefix": "taske",
    "body": ["task: ${1:Description} !${2|low,medium,high,critical|} @${3:owner} 📅 ${4:date}"],
    "description": "Task with emoji shortcut syntax"
  },
  "Done": {
    "prefix": "done",
    "body": ["done: ${1:Completed task}"],
    "description": "Completed task"
  },
  "Note": {
    "prefix": "note",
    "body": ["note: ${1:Note content}"],
    "description": "Note block"
  },
  "Info": {
    "prefix": "info",
    "body": ["info: ${1:Information}"],
    "description": "Info callout"
  },
  "Warning": {
    "prefix": "warning",
    "body": ["warning: ${1:Warning message}"],
    "description": "Warning callout"
  },
  "Tip": {
    "prefix": "tip",
    "body": ["tip: ${1:Helpful tip}"],
    "description": "Tip callout"
  },
  "Success": {
    "prefix": "success",
    "body": ["success: ${1:Success message}"],
    "description": "Success callout"
  },
  "Question": {
    "prefix": "question",
    "body": ["question: ${1:Open question?}"],
    "description": "Open question"
  },
  "Checkbox todo": {
    "prefix": "todo",
    "body": ["[ ] ${1:Task description}"],
    "description": "Unchecked checkbox"
  },
  "Checkbox done": {
    "prefix": "xdone",
    "body": ["[x] ${1:Completed task}"],
    "description": "Checked checkbox"
  },
  "Code block": {
    "prefix": "code",
    "body": ["code:", "${1:# code here}", "end:"],
    "description": "Code block"
  },
  "Table": {
    "prefix": "table",
    "body": [
      "headers: ${1:Column 1} | ${2:Column 2} | ${3:Column 3}",
      "row: ${4:Value 1} | ${5:Value 2} | ${6:Value 3}"
    ],
    "description": "Table with headers and row"
  },
  "Image": {
    "prefix": "image",
    "body": ["image: ${1:Alt text} | at: ${2:path/to/image.png} | caption: ${3:Caption}"],
    "description": "Image block"
  },
  "Link": {
    "prefix": "link",
    "body": ["link: ${1:Label} | to: ${2:https://example.com}"],
    "description": "External link"
  },
  "Divider": {
    "prefix": "divider",
    "body": ["divider: ${1:Section separator}"],
    "description": "Visual divider"
  },
  "Document template": {
    "prefix": "newdoc",
    "body": [
      "title: ${1:Document Title}",
      "summary: ${2:Brief description}",
      "",
      "section: ${3:First Section}",
      "${4:Content here}"
    ],
    "description": "New document scaffold"
  },
  "Meeting notes template": {
    "prefix": "meeting",
    "body": [
      "title: ${1:Meeting} - ${2:Date}",
      "summary: ${3:Meeting purpose}",
      "",
      "section: Agenda",
      "- ${4:Topic 1}",
      "- ${5:Topic 2}",
      "",
      "section: Action Items",
      "task: ${6:Follow-up} | owner: ${7:name} | due: ${8:date}"
    ],
    "description": "Meeting notes document"
  }
}
